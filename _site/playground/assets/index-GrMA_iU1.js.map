export default "-- Inspiration: https://www.scattered-thoughts.net/writing/relational-ui/\napp Chat\n    @substrate(browser-local)\n\ndata User\n    name: Text\n\ndata Message\n    text:    Text\n    sent_by: User\n    liked_by: many User\n\nstate current_user: User\n\nevent SeedSynthetic()\nevent MessageSent(sent_by: User, text: Text)\nevent MessageLiked(msg: Message, liker: User)\nevent MessageDeleted(msg: Message)\nevent UserSelected(user: User) @local\n\non SeedSynthetic()\n    User insert {id: 'u_alice', name: 'Alice'}\n    User insert {id: 'u_bob', name: 'Bob'}\n    User insert {id: 'u_chloe', name: 'Chloe'}\n    Message insert {id: 'm1', sent_by: 'u_alice', text: 'Welcome to Elysium chat'}\n    Message insert {id: 'm2', sent_by: 'u_bob', text: 'Like messages to test many-to-many joins'}\n    Message_liked_by insert {id: 'l1', message: 'm1', user: 'u_bob'}\n    Message_liked_by insert {id: 'l2', message: 'm1', user: 'u_chloe'}\n    set current_user = 'u_alice'\n\non MessageSent(sent_by, text)\n    Message insert {sent_by, text}\n\non MessageLiked(msg, liker)\n    Message_liked_by insert {message: msg, user: liker}\n\non MessageDeleted(msg)\n    Message where .id = msg delete\n\non UserSelected(user)\n    set current_user = user\n\nquery likesWithUsers = Message_liked_by select {id, messageId: .message.id, likerName: .user.name}\n\nview ChatApp()\n    local newMsgText: Text = ''\n\n    <div className=\"chat-root\">\n        <h1>Chat App</h1>\n\n        <div className=\"toolbar\">\n            <button on:click => do SeedSynthetic()>Load Synthetic Data</button>\n            <span>Current user: {current_user}</span>\n        </div>\n\n        <div className=\"users\">\n            {User as u select <button on:click => do UserSelected(u)>{u.name}</button>}\n        </div>\n\n        <table>\n            {Message as msg select <MessageItem msg />}\n        </table>\n\n        <input\n            className=\"send-message\"\n            placeholder=\"Say something ...\"\n            value=newMsgText\n            on:input=(e) => set newMsgText = e.target.value\n            on:keyDown('Enter') => {\n                do MessageSent(current_user, newMsgText)\n                set newMsgText = ''\n            }\n        />\n    </div>\n\nview MessageItem(msg: Message)\n    <tr>\n        <td>{msg.sent_by}:</td>\n        <td>{msg.text}</td>\n        <td>{\n            likesWithUsers as l\n            where l.messageId = msg.id \n            select <div>{l.likerName}{' likes this!'}</div>\n        }</td>\n        <td><button on:click => do MessageLiked(msg, current_user)>Like!</button></td>\n        if msg.sent_by = current_user then <td><button on:click => do MessageDeleted(msg)>Delete</button></td>\n    </tr>\n"